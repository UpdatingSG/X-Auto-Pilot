# Database
DATABASE_URL=postgresql+asyncpg://xautopilot:xautopilot@localhost:5432/xautopilot

# Environment: development | staging | production
APP_ENV=development

# JWT signing — use openssl rand -hex 32 in staging/production
SECRET_KEY=dev-secret-change-in-production

# X OAuth token encryption (Fernet key).
# Required in staging/production. In development, omitted = derived from SECRET_KEY.
# Generate: scripts/generate-secrets.sh
# TOKEN_ENCRYPTION_KEY=

# Frontend
CORS_ORIGINS=["http://localhost:3000"]
FRONTEND_URL=http://localhost:3000

# X / Twitter — mock for local dev, live for production
X_API_MODE=mock
# X_API_MODE=live
# X_CLIENT_ID=your_client_id_from_developer_portal
# X_CLIENT_SECRET=your_client_secret
# Callback goes to Next.js (avoids ngrok browser warning on free tier)
X_REDIRECT_URI=http://localhost:3000/settings/x/callback

# OpenAI (Step 4) — server-side only, never expose to frontend
LLM_MODE=mock
# LLM_MODE=live
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# LLM_DAILY_BUDGET_USD=5.0

# Background worker (Step 5)
WORKER_ENABLED=true
WORKER_TICK_INTERVAL_SECONDS=60
WORKER_MANUAL_TICK_ENABLED=true
