# # Production template — copy values into AWS Secrets Manager / Doppler / Vault.
# # Do NOT commit filled-in values. Run: scripts/generate-secrets.sh

# APP_ENV=production

# # openssl rand -hex 32
# SECRET_KEY=REPLACE_ME

# # Fernet key — MUST differ from SECRET_KEY (scripts/generate-secrets.sh)
# TOKEN_ENCRYPTION_KEY=REPLACE_ME

# # HTTPS only in production
# CORS_ORIGINS=["https://your-app.example.com"]
# FRONTEND_URL=https://your-app.example.com
# X_REDIRECT_URI=https://your-app.example.com/settings/x/callback

# DATABASE_URL=postgresql+asyncpg://user:pass@your-db-host:5432/xautopilot

# X_API_MODE=live
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# LLM_MODE=live
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# LLM_DAILY_BUDGET_USD=5.0

