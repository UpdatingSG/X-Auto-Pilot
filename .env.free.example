# Free deployment — $0/month (no Fly.io, no credit card)
#
# Stack:
#   Web  → Vercel (free)
#   API  → Render free tier (1 web service)
#   DB   → Neon (free Postgres)

# --- Render API env vars (set in Render dashboard) ---
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# SECRET_KEY=
# TOKEN_ENCRYPTION_KEY=
# CORS_ORIGINS=["https://YOUR_APP.vercel.app"]
# FRONTEND_URL=https://YOUR_APP.vercel.app
# X_REDIRECT_URI=https://YOUR_APP.vercel.app/settings/x/callback
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
