# Copy to .env.production and fill in values before: docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
# Generate secrets: ./scripts/generate-secrets.sh

# --- Domains (point DNS A records to your VPS IP) ---
APP_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com
ACME_EMAIL=you@yourdomain.com

FRONTEND_URL=https://app.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
CORS_ORIGINS=["https://app.yourdomain.com"]
X_REDIRECT_URI=https://app.yourdomain.com/settings/x/callback

# --- Database ---
POSTGRES_USER=xautopilot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=xautopilot

# --- Secrets (run ./scripts/generate-secrets.sh) ---
SECRET_KEY=
TOKEN_ENCRYPTION_KEY=

# --- X / Twitter ---
X_API_MODE=live
X_CLIENT_ID=
X_CLIENT_SECRET=

# --- LLM (OpenAI or Groq-compatible) ---
LLM_MODE=live
OPENAI_API_KEY=
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1
LLM_DAILY_BUDGET_USD=5.0
